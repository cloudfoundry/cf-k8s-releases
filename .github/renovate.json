{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/helm/Chart.yaml$/",
        "/helm/values.yaml$/",
        "/docker-bake.hcl$/", 
        "/^\\.github/workflows/.+\\.yaml$/",
        "/^\\.github/actions/init/action\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: dataSource=(?<datasource>.*?) depName=(?<depName>.*?)( packageName=(?<packageName>.*?))?\\s+\\S+?(: | = )\"?(?<currentValue>[\\d\\w\\.-]+)\"?"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "helm-values": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "dockerfile"
      ],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "cloudfoundry/*",
        "pivotal/*"
      ],
      "automerge": true
    }
  ]
}
