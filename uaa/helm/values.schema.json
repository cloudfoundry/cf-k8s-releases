{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "address": {
      "type": "string"
    },
    "loginAddress": {
      "type": "string"
    },
    "certificateSecret": {
      "type": "string"
    },
    "uaadb": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "user": {
          "type": "string"
        },
        "password": {
          "type": ["string", "null"]
        },
        "address": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "caCertificateSecret": {
          "type": "string"
        },
        "skipSSLVerify": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "global": {
      "type": "object"
    },
    "hostname": {
      "type": "string"
    },
    "uaaConfigOverrides": {
      "type": ["object", "null"]
    },
    "image": {
      "additionalProperties": false,
      "properties": {
        "imagePullPolicy": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "nodeSelector": {
      "type": ["object", "null"]
    },
    "oauthClientsSecret": {
      "type": ["string", "null"]
    },
    "routeRegistrar": {
      "additionalProperties": false,
      "properties": {
        "image": {
          "additionalProperties": false,
          "properties": {
            "imagePullPolicy": {
              "type": "string"
            },
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "resources": {
          "type": ["object", "null"]
        }
      },
      "type": "object"
    },
    "tolerations": {
      "type": ["array", "null"],
      "items": {
        "additionalProperties": false,
        "properties": {
          "effect": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "operator": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "effect",
          "key",
          "operator",
          "value"
        ],
        "type": "object"
      }
    },
    "uaaAdminSecret": {
      "type": ["string", "null"]
    },
    "scim": {
      "additionalProperties": false,
      "properties": {
        "users": {
          "type": "array",
          "items": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "password": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              },
              "groups": {
                "type": "string"
              },
              "origin": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "password",
              "email",
              "groups",
              "origin"
            ],
            "type": "object"
          }
        }
      },
      "type": "object"
    },
    "oauth": {
      "additionalProperties": false,
      "properties": {
        "clients": {
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}